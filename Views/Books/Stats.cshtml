@model List<MiniLibrary.Web.ViewModels.BookListItemViewModel>

<div class="stats-page-container">
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
        <div>
            <h2 style="font-size: 2rem; color: #5c554a; margin: 0;">📊 Inventory Analytics Ledger</h2>
            <p style="color: #8c816f; margin: 5px 0 0 0;">High-level dashboard computing active database records.</p>
        </div>
        <a href="/Books" class="badge badge-success" style="text-decoration: none; padding: 10px 15px; background: #f4efe6; color: #5c554a; border: 1px solid #e6decb;">➔ Back to Catalog</a>
    </div>

    <div class="stat-grid" style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px; margin-bottom: 35px;">
        <div style="background: white; border: 1px solid #e6decb; border-radius: 12px; padding: 20px; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.01);">
            <div style="font-size: 2rem; font-weight: bold; color: #8c7a6b;">@ViewBag.TotalTitles</div>
            <div style="font-size: 0.85rem; color: #7c7261; margin-top: 5px;">Total Book Titles</div>
        </div>
        <div style="background: white; border: 1px solid #e6decb; border-radius: 12px; padding: 20px; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.01);">
            <div style="font-size: 2rem; font-weight: bold; color: #2b6cb0;">@ViewBag.TotalCopies</div>
            <div style="font-size: 0.85rem; color: #7c7261; margin-top: 5px;">Total Inventory Copies</div>
        </div>
        <div style="background: white; border: 1px solid #e6decb; border-radius: 12px; padding: 20px; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.01);">
            <div style="font-size: 1.5rem; font-weight: bold; color: #2f855a; line-height: 2rem;">@ViewBag.TotalAssetValue.ToString("N0")</div>
            <div style="font-size: 0.85rem; color: #7c7261; margin-top: 5px;">Total Vault Asset Value (VND)</div>
        </div>
        <div style="background: #fdf2f2; border: 1px solid #f8b4b4; border-radius: 12px; padding: 20px; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.01);">
            <div style="font-size: 2rem; font-weight: bold; color: #c53030;">@ViewBag.OutOfStockCount</div>
            <div style="font-size: 0.85rem; color: #9b2c2c; margin-top: 5px;">Absolute Depleted Units</div>
        </div>

        <div style="background: #fffaf0; border: 1px solid #feebc8; border-radius: 12px; padding: 20px; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.01);">
            <div style="font-size: 2rem; font-weight: bold; color: #dd6b20;">@ViewBag.LowStockCount</div>
            <div style="font-size: 0.85rem; color: #c05621; margin-top: 5px;">Critical Low Threshold</div>
        </div>
    </div>

    <h3 style="color: #5c554a; border-bottom: 2px solid #eddcc6; padding-bottom: 8px;">📊 Detailed Relational Breakdown Table</h3>
    <table class="table" style="width: 100%; border-collapse: collapse; margin-top: 15px;">
        <thead>
            <tr style="background-color: #fdfaf4;">
                <th style="padding: 12px;">Book Title</th>
                <th style="padding: 12px;">Category Unit</th>
                <th style="padding: 12px; text-align: right;">Unit Rental Valuation</th>
                <th style="padding: 12px; text-align: center;">In-Stock Count</th>
                <th style="padding: 12px; text-align: right;">Calculated Net Asset worth</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var b in Model)
            {
                <tr>
                    <td style="padding: 12px;"><strong>@b.Title</strong></td>
                    <td style="padding: 12px;"><span class="badge" style="background:#f4efe6; color:#7c7261;">@b.CategoryName</span></td>
                    <td style="padding: 12px; text-align: right;">@b.RentalPrice.ToString("N0") VND</td>
                    <td style="padding: 12px; text-align: center; font-weight: bold;">@b.AvailableCopies units</td>
                    <td style="padding: 12px; text-align: right; font-weight: bold; color: #2f855a;">@((b.RentalPrice * b.AvailableCopies).ToString("N0")) VND</td>
                </tr>
            }
        </tbody>
    </table>
</div>