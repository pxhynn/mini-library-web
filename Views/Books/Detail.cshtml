@model MiniLibrary.Web.Models.Book

<div class="detail-page-container">
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
        <div>
            <h2 style="font-size: 2rem; color: #5c554a; margin: 0;">📘 Book Detail Analytics</h2>
            <p style="color: #8c816f; margin: 5px 0 0 0;">Granular structural properties of the selected database node.</p>
        </div>
        <a href="/Books" class="badge badge-success" style="text-decoration: none; padding: 10px 15px; background: #f4efe6; color: #5c554a; border: 1px solid #e6decb;">➔ Back to Catalog</a>
    </div>

    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 30px; align-items: start;">
        <div style="background: white; border-radius: 12px; border: 1px solid #e6decb; overflow: hidden; box-shadow: 0 2px 5px rgba(0,0,0,0.01);">
            <table class="table" style="margin: 0; width: 100%;">
                <tr><th style="width: 30%; background: #fdfaf4;">System ID</th><td>@Model.Id</td></tr>
                <tr><th style="background: #fdfaf4;">Book Code</th><td><strong style="color: #c2410c;">@Model.BookCode</strong></td></tr>
                <tr><th style="background: #fdfaf4;">Title</th><td><strong>@Model.Title</strong></td></tr>
                <tr><th style="background: #fdfaf4;">Author</th><td>@Model.Author</td></tr>
                <tr><th style="background: #fdfaf4;">Classification</th><td>@Model.Category?.Name</td></tr>
                <tr><th style="background: #fdfaf4;">Base Rental Rate</th><td>@Model.RentalPrice.ToString("N0") VND</td></tr>
                <tr><th style="background: #fdfaf4;">Available Copies</th><td>@Model.AvailableCopies units</td></tr>
                <tr><th style="background: #fdfaf4;">System Status</th><td>
                    <span class="badge" style="background-color: @(Model.AvailableCopies <= 0 ? "#fce8e6" : "#e6f4ea"); color: @(Model.AvailableCopies <= 0 ? "#c5221f" : "#137333")">
                        @(Model.AvailableCopies <= 0 ? "Out of Stock" : "Available")
                    </span>
                </td></tr>
            </table>
        </div>

        <div class="side-cards-stack">
            <div style="background: #fffcf4; border: 1px solid #eddcc6; border-radius: 12px; padding: 20px; margin-bottom: 20px;">
                <h4 style="margin: 0 0 10px 0; color: #8c7a6b; font-size: 0.9rem; text-transform: uppercase;">Stock Status Flag</h4>
                <h3 style="margin: 0 0 8px 0; color: #b45309;">@(Model.AvailableCopies <= 0 ? "Reorder Mandatory" : "Operational")</h3>
                <p style="margin: 0; font-size: 0.85rem; color: #7c7261;">
                    @(Model.AvailableCopies <= 0 ? "The library capacity for this specific unit has hit zero bounds." : "Current available threshold is stable for student borrowing flow.")
                </p>
            </div>

            <div style="background: #f4f8fa; border: 1px solid #cfe2e6; border-radius: 12px; padding: 20px;">
                <h4 style="margin: 0 0 10px 0; color: #5b7c85; font-size: 0.9rem; text-transform: uppercase;">Security Deposit Valuation</h4>
                <h3 style="margin: 0 0 8px 0; color: #1d4ed8;">@((Model.RentalPrice * 2).ToString("N0")) VND</h3>
                <p style="margin: 0; font-size: 0.85rem; color: #526e75;">Calculated at a fixed 200% rate of base copyright index values.</p>
            </div>
        </div>
    </div>
</div>