@model List<MiniLibrary.Web.Models.BorrowTicket>

<h2>📜 System Borrowing History Ledger</h2>
<p style="color: #8c816f;">Audit logs demonstrating advanced Include mapping projections using <strong>AsNoTracking</strong> pattern.</p>

@foreach (var ticket in Model)
{
    <div style="background: white; border:1px solid #eddcc6; border-radius:8px; padding:20px; margin-bottom:20px;">
        <div style="display:flex; justify-content:space-between; border-bottom:1px solid #f0eae1; padding-bottom:10px; margin-bottom:15px;">
            <span><strong>Ticket ID:</strong> #@ticket.Id</span>
            <span><strong>Date:</strong> @ticket.BorrowedAt.ToString("dd/MM/yyyy HH:mm")</span>
            <span><strong>Total Deposit Bond:</strong> <b style="color:#c2410c;">@ticket.TotalDeposit.ToString("N0") VND</b></span>
        </div>
        <p style="margin:0 0 10px 0;"><strong>Reader Account:</strong> @ticket.Borrower?.Name (@ticket.Borrower?.Email)</p>
        
        <h4 style="margin:10px 0 5px 0; color:#6b6152;">Items Checklist:</h4>
        <ul style="margin:0; padding-left:20px;">
            @foreach(var detail in ticket.BorrowDetails)
            {
                <li>Code: <b>@detail.Book?.BookCode</b> - Title: <i>@detail.Book?.Title</i> | Borrowed amount: <b>@detail.Quantity units</b> (Deposit Value Rate: @detail.DepositPrice.ToString("N0") VND/unit)</li>
            }
        </ul>
    </div>
}